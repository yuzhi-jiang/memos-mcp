# Memos API配置
MEMOS_URL=http://your-memos-instance-url # 例如：http://localhost:5230
MEMOS_API_KEY=your-memos-api-key # 从Memos设置页面获取
MEMOS_ADMIN_API_KEY=your-memos-admin-api-key # 用于获取所有用户
DEFAULT_TAG=mcp # 默认标签，创建备忘录时会自动添加
MCP_TRANSPORT=stdio # 可选: stdio 或 streamable-http
MCP_HOST=0.0.0.0 # HTTP 模式监听地址
MCP_PORT=3002 # HTTP 模式监听端口
MCP_STREAMABLE_HTTP_PATH=/mcp # HTTP 模式访问路径
